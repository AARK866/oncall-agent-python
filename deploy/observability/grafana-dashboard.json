{
  "annotations": {
    "list": []
  },
  "editable": true,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "expr": "sum(rate(oncall_http_requests_total[5m]))",
          "legendFormat": "requests"
        }
      ],
      "title": "Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(oncall_http_requests_total{status_class=\"5xx\"}[5m])) / clamp_min(sum(rate(oncall_http_requests_total[5m])), 0.001)",
          "legendFormat": "5xx ratio"
        }
      ],
      "title": "Server Error Ratio",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(oncall_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ],
      "title": "HTTP P95 Latency",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 4,
      "targets": [
        {
          "expr": "sum by (tool, outcome) (rate(oncall_tool_calls_total[5m]))",
          "legendFormat": "{{tool}} {{outcome}}"
        }
      ],
      "title": "Agent Tool Calls",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 5,
      "targets": [
        {
          "expr": "sum by (task_kind, mode, outcome) (rate(oncall_task_dispatches_total[5m]))",
          "legendFormat": "{{task_kind}} {{mode}} {{outcome}}"
        }
      ],
      "title": "Task Dispatches",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 16
      },
      "id": 6,
      "targets": [
        {
          "expr": "increase(oncall_audit_write_failures_total[24h])"
        }
      ],
      "title": "Audit Write Failures (24h)",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "oncall-agent",
    "ai-agent"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "title": "OnCall Agent Operations",
  "uid": "oncall-agent-ops",
  "version": 1
}
