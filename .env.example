APP_NAME=OnCall Agent Python
APP_ENV=local
APP_VERSION=0.1.0
API_PREFIX=/api

# Enterprise mode: use LangChain + a real OpenAI-compatible chat model.
LLM_PROVIDER=langchain-openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=6

# Local incident history storage.
INCIDENT_DB_PATH=app/data/oncall_agent.db

# mock is available now. real is reserved for Prometheus/Loki/GitLab connectors.
OPS_TOOL_MODE=mock

# Required only when OPS_TOOL_MODE=real.
PROMETHEUS_BASE_URL=
LOKI_BASE_URL=
GITLAB_BASE_URL=
GITLAB_TOKEN=
GITLAB_PROJECT_ID=

# local is stable for learning. Use langgraph after installing the dependency.
OPS_GRAPH_RUNTIME=local

# keyword, vector, or hybrid.
KNOWLEDGE_RETRIEVER_MODE=keyword
