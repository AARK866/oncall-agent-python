APP_NAME=OnCall Agent Python
APP_ENV=local
APP_VERSION=0.1.0
API_PREFIX=/api

# LLM
# Keep mock until LLM_API_KEY is ready. Then change to langchain-openai.
LLM_PROVIDER=langchain-openai
LLM_MODEL=deepseek-chat
LLM_API_KEY=sk-abf1f0a7482b4d9d8d2779b27c8d22db
LLM_BASE_URL=https://api.deepseek.com
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=6

# Embedding
# Keep hash until EMBEDDING_API_KEY is ready. Then change to langchain-openai.
EMBEDDING_PROVIDER=openai-compatible
EMBEDDING_MODEL=bge-m3
EMBEDDING_API_KEY=ollama
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_DIMENSIONS=1024
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_MAX_RETRIES=6

# Knowledge vector store
# Keep in_memory until Milvus is running. Then change to milvus.
# --- 鏍稿績妯″紡鍒囨崲 ---
KNOWLEDGE_RETRIEVER_MODE=vector
KNOWLEDGE_VECTOR_STORE=milvus

# --- Milvus 鏁版嵁搴撹繛鎺?---
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_DB_NAME=default
MILVUS_COLLECTION_NAME=oncall_runbook_chunks

# --- Milvus 鍐呴儴瀛楁鏄犲皠 ---
MILVUS_VECTOR_FIELD=vector
MILVUS_PRIMARY_FIELD=chunk_id
MILVUS_METRIC_TYPE=COSINE

# Local incident history storage.
INCIDENT_DB_PATH=app/data/oncall_agent.db

# mock is available now. real is reserved for Prometheus/Loki/GitLab connectors.
OPS_TOOL_MODE=mock

# Required only when OPS_TOOL_MODE=real.
PROMETHEUS_BASE_URL=http://localhost:9090
PROMETHEUS_TIMEOUT_SECONDS=10
LOKI_BASE_URL=http://localhost:3100
LOKI_TIMEOUT_SECONDS=10
# --- GitHub 婧愮爜璇诲彇鏉冮檺閰嶇疆 ---
GITHUB_TOKEN=
GITHUB_REPO=AARK866/oncall-agent-python
GITHUB_BRANCH=main
GITHUB_TIMEOUT_SECONDS=10

# local is stable for learning. Use langgraph after installing the dependency.
OPS_GRAPH_RUNTIME=local
