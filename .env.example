APP_NAME=OnCall Agent Python
APP_ENV=local
APP_VERSION=0.1.0
API_PREFIX=/api

# mock or openai-compatible
LLM_PROVIDER=mock
LLM_MODEL=mock-oncall-agent
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT_SECONDS=30

# Local incident history storage.
INCIDENT_DB_PATH=app/data/oncall_agent.db

# mock is available now. real is reserved for Prometheus/Loki/GitLab connectors.
OPS_TOOL_MODE=mock

# local is stable for learning. Use langgraph after installing the dependency.
OPS_GRAPH_RUNTIME=local

# keyword, vector, or hybrid.
KNOWLEDGE_RETRIEVER_MODE=keyword
